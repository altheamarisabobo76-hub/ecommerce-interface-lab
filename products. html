<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Products</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<main>
    <section class="product-grid">

        <div class="product-card" id="product1">
            <h4>Nike Shoes</h4>
            <button class="add-to-cart">Add to Cart</button>
        </div>

    </section>
</main>

<aside>
    <form>
        <h3>Filter</h3>
        <label><input type="checkbox"> On Sale</label><br>
        <label><input type="radio" name="price"> Under 1500 pesos</label><br>
        <label><input type="radio" name="price"> Over 1500 pesos</label>
    </form>
</aside>

<script src="script.js"></script>
</body>
</html>
